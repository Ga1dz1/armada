# No ID_INPUT_JOYSTICK tag: InputPlumber's composite_device.yaml matches this
# device by phys_path/handler (not by udev class), and its own driver-type
# detection already defaults to the gamepad implementation for untagged
# devices (see get_driver_type() in InputPlumber's src/input/source/evdev.rs)
# - so the tag isn't needed for InputPlumber to work. What it WAS doing is
# making Steam/SDL's udev-based joystick enumeration see this raw node as a
# second, ghost controller once "passthrough: true" (in
# 01-retroid-controller.yaml, needed for the reactive LED mode) leaves it
# ungrabbed/visible. Leaving the class untagged keeps Steam from picking it
# up at all, while InputPlumber and armada-stick-led's reactive reader both
# keep working off phys_path/MODE=0666 alone.
SUBSYSTEM=="input", ATTRS{name}=="Retroid Pocket Gamepad", MODE="0666"
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT}=="1", ATTRS{name}=="pmi8998_haptics", TAG+="uaccess", ENV{FEEDBACKD_TYPE}="vibra"

# Marks the raw event node so waydroid-input-setup can find it and expose it
# to Waydroid, same mechanism as the AYN family's own rule in
# 70-armada-inputplumber.rules. MODE/uaccess for this device are already
# handled by the line above - passthrough (01-retroid-controller.yaml)
# already leaves it visible, this just tags which node it is.
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="Retroid Pocket Gamepad", ENV{ARMADA_WAYDROID_GAMEPAD}="1"
