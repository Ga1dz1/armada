#!/bin/bash
# Regenerate the SM8250 GRUB config (linux/initrd/devicetree paths) to match
# whichever deployment is CURRENTLY the boot default.
#
# Those paths live under ostree's boot-checksum-scoped directory
# (/ostree/boot.1/<os>-<bootcsum>/...), and an OTA update that changes the
# kernel or initrd content changes that checksum - the OLD deployment's
# boot files eventually get pruned by ostree, and a GRUB config still
# pointing at them can no longer find its kernel, initrd, or devicetree.
# The SD-card image build (finalize-armada-image.sh) and the internal-
# storage installer (armada-installer's stage_sm8250_grub, which now just
# calls this) both write this config exactly ONCE, at build/install time -
# nothing kept it in sync with later deployments before this existed.
# Confirmed live: an SM8250 device installed to internal storage that
# later took an OTA update failed to boot ("DSI PLL(0) lock failed" in the
# kernel log - a devicetree/kernel clock mismatch, consistent with GRUB
# handing the new kernel a stale or wrong devicetree).
#
# Called by armada-installer at install time and by armada-bootimg-finalize
# on every OTA finalization (both SD card and internal storage - the SD
# card image build stages the same files this refreshes), so it can't go
# stale on either path again.
set -euo pipefail
source /usr/lib/armada/storage-lib

BOOTROOT="${BOOTROOT:-/boot}"
ESP="${ESP:-/boot/efi}"

eval "$(/usr/libexec/armada/device-env 2>/dev/null)" || true
# SM8250 always boots through GRUB (see the ABL comment above) - stage it
# unconditionally rather than gating on whether EFI/BOOT/BOOTAA64.EFI
# already exists. That existence check used to guard this script too, but
# armada-installer's internal-storage install always mkfs's the ESP from
# scratch right before calling this, so the file can never pre-exist there
# - the guard silently skipped writing both the EFI binary and grub.cfg on
# every eMMC install, leaving a formatted-but-empty ESP (confirmed live:
# device shows no bootable GRUB after an internal-storage install).
[[ "${ARMADA_SOC_CLASS:-}" == SM8250 ]] || exit 0

model=$(tr -d '\0' </sys/firmware/devicetree/base/model 2>/dev/null)
[[ -n $model ]] || { echo "armada-grub-update: could not read this device's model from devicetree" >&2; exit 1; }

entry=$(armada_default_bls_entry "$BOOTROOT")
[[ -n $entry ]] || { echo "armada-grub-update: no BLS entry under ${BOOTROOT}/loader/entries" >&2; exit 1; }

linux=$(sed -n 's/^linux //p' "$entry" | head -1)
initrd=$(sed -n 's/^initrd //p' "$entry" | head -1)
options=$(sed -n 's/^options //p' "$entry" | head -1)
fdtdir=$(sed -n 's/^fdtdir //p' "$entry" | head -1)
[[ -n $linux && -n $initrd && -n $options && -n $fdtdir ]] \
    || { echo "armada-grub-update: could not parse BLS entry ${entry}" >&2; exit 1; }

# BLS paths carry a /boot prefix; GRUB roots directly on the BOOT partition
# by UUID below, so the same paths are used without that prefix - matching
# finalize-armada-image.sh's own (unprefixed) convention.
linux=${linux#/boot}
initrd=${initrd#/boot}
fdtdir=${fdtdir#/boot}

# Match this device's own model string (the same one device-env's case
# statement matches on) against each candidate DTB's compiled strings
# table - fdtget/dtc isn't installed on-device, but a compiled DTB stores
# string properties as plain null-terminated ASCII, so a raw substring
# search for the exact model text is reliable without parsing the FDT.
match=""
for dtb in "${BOOTROOT}${fdtdir}"/qcom/sm8250-retroidpocket-*.dtb; do
    [[ -f $dtb ]] || continue
    grep -qa -F -- "$model" "$dtb" && { match=$(basename "$dtb"); break; }
done
[[ -n $match ]] || { echo "armada-grub-update: no DTB under ${fdtdir}/qcom matches this device's model (${model})" >&2; exit 1; }
dtb_rel="${fdtdir}/qcom/${match}"
[[ -f "${BOOTROOT}${dtb_rel}" ]] || { echo "armada-grub-update: ${dtb_rel} missing under ${BOOTROOT}" >&2; exit 1; }

BOOT_UUID=$(findmnt -no UUID "$BOOTROOT" 2>/dev/null || true)
[[ -n $BOOT_UUID ]] || { echo "armada-grub-update: could not determine the boot partition's UUID" >&2; exit 1; }

grub_dir="${ESP}/boot/grub"
install -Dpm 0644 /usr/share/armada/grub/bootaa64.efi "${ESP}/EFI/BOOT/BOOTAA64.EFI"
install -d -m 0755 "$grub_dir"
install -m 0644 /usr/share/armada/grub/dejavu-mono.pf2 "$grub_dir/dejavu-mono.pf2"

{
    echo "insmod part_gpt"
    echo "insmod part_msdos"
    echo "insmod fat"
    echo "insmod ext2"
    echo
    echo "set lang=en_US"
    echo "loadfont /boot/grub/dejavu-mono.pf2"
    # Matches ROCKNIX's own value for this panel/mounting family
    # (RP5/Flip2/Mini/Mini V2) - live-tested correct on Mini V2.
    echo "set rotation=270"
    echo "set gfxmode=auto"
    echo "insmod efi_gop"
    echo "insmod gfxterm"
    echo "terminal_output gfxterm"
    echo
    echo "search --fs-uuid --set root --no-floppy ${BOOT_UUID}"
    echo
    echo "set timeout_style=menu"
    echo "set timeout=3"
    echo
    printf "menuentry 'Armada' {\n"
    printf "    linux %s %s\n" "$linux" "$options"
    printf "    initrd %s\n" "$initrd"
    printf "    devicetree %s\n" "$dtb_rel"
    printf "}\n"
} > "${grub_dir}/grub.cfg"

echo "armada-grub-update: refreshed GRUB config for ${linux##*/}"
