def _default_stick_side_state():
    return {
        "mode": "static",
        "color": "0050FF",
        "colorSource": "static",
        "chargingIndicator": True,
        "duotoneColorA": "0050FF",
        "duotoneColorB": "FFD700",
        "duotoneOrientation": "horizontal",
        "chase": False,
        "compass": False,
        "seesaw": False,
        "params": {},
    }


def _stick_led_state():
    result = subprocess.check_output(["/usr/libexec/armada/stick-led-color", "get"], text=True, timeout=5)
    state = {"screenLink": False, "enabled": True, "maxBrightness": 1.0, "sides": {"l": _default_stick_side_state(), "r": _default_stick_side_state()}, "flashColors": {}}
    for line in result.splitlines():
        key, sep, value = line.partition("=")
        if not sep:
            continue
        key, value = key.strip(), value.strip()
        if key == "screen_link":
            state["screenLink"] = value == "1"
            continue
        if key == "enabled":
            state["enabled"] = value == "1"
            continue
        if key == "max_brightness":
            try:
                state["maxBrightness"] = max(0.0, min(1.0, float(value)))
            except ValueError:
                pass
            continue
        if key.startswith("flash_") and key[len("flash_"):] in FLASH_BUTTONS:
            if re.fullmatch(r"[0-9A-Fa-f]{6}", value or ""):
                state["flashColors"][key[len("flash_"):]] = value.upper()
            continue
        if key.endswith("_l"):
            side, base = "l", key[:-2]
        elif key.endswith("_r"):
            side, base = "r", key[:-2]
        else:
            continue
        s = state["sides"][side]
        if base == "mode":
            s["mode"] = value
        elif base == "color":
            s["color"] = value
        elif base == "color_source":
            s["colorSource"] = value
        elif base == "charging_indicator":
            s["chargingIndicator"] = value == "1"
        elif base == "duotone_color_a":
            s["duotoneColorA"] = value
        elif base == "duotone_color_b":
            s["duotoneColorB"] = value
        elif base == "duotone_orientation":
            s["duotoneOrientation"] = value
        elif base == "chase":
            s["chase"] = value == "1"
        elif base == "compass":
            s["compass"] = value == "1"
        elif base == "seesaw":
            s["seesaw"] = value == "1"
        elif "_" in base and base.split("_", 1)[0] in STICK_LED_PARAMS:
            try:
                s["params"][base] = float(value)
            except ValueError:
                pass
    return state


