def action_write_config(request):
    name = str(request.get("name", ""))
    text = request.get("text")
    if name not in CONFIG_PATHS or not isinstance(text, str):
        raise ValueError("invalid config write")
    if len(text.encode("utf-8")) > MAX_REQUEST:
        raise ValueError("config payload too large")
    if name == "calibration":
        params = json.loads(text)
        # Each supported gamepad driver exposes the same calibration
        # parameter ABI under its own /sys/module/<name>/parameters -
        # rsinput on AYN devices, retroid (drivers/input/joystick/retroid.c)
        # on Retroid Pocket. Only one of these will exist on any device.
        driver_params = next(
            (p for name in ("rsinput", "retroid") if (p := Path(f"/sys/module/{name}/parameters")).exists()),
            None,
        )
        if driver_params is None:
            raise RuntimeError("controller calibration is not supported on this device")
        for param in CALIBRATION_PARAMS:
            if param in params:
                (driver_params / param).write_text(str(int(params[param])), encoding="utf-8")
        (driver_params / "update_params").write_text("1", encoding="utf-8")
    atomic_write(CONFIG_PATHS[name], text)
    if name == "power":
        run(["/usr/bin/armada-power", "reload"], timeout=15)
    return {"ok": True}


