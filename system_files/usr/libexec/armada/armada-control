def atomic_write(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(text)
        os.chmod(tmp, 0o644)
        os.replace(tmp, path)
    finally:
        try:
            os.unlink(tmp)
        except FileNotFoundError:
            pass


def run(command, timeout=20):
    subprocess.run(command, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, timeout=timeout)


def ssh_enabled():
    result = subprocess.run(
        ["/usr/bin/systemctl", "is-active", "sshd"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        timeout=5,
    )
    return result.stdout.strip() == "active"


def device_env():
    result = subprocess.check_output(["/usr/libexec/armada/device-env"], text=True, timeout=5)
    env = {}
    for line in result.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        try:
            env[key] = shlex.split(value)[0] if value else ""
        except ValueError:
            env[key] = value
    return env


def drm_connectors():
    # gamescope-session-plus/sessions.d/steam picks its output by connector
    # name (--prefer-output), so that's the unit both listing and applying a
    # choice operate on - not a friendlier "monitor 1/2" index that could
    # silently shift if a cable is unplugged between listing and applying.
    connectors = []
    drm = Path("/sys/class/drm")
    if not drm.is_dir():
        return connectors
    for card_dir in sorted(drm.glob("card*-*")):
        status_path = card_dir / "status"
        if not status_path.is_file():
            continue
        try:
            status = status_path.read_text(encoding="utf-8").strip()
        except OSError:
            continue
        name = card_dir.name.split("-", 1)[1]
        modes = []
        modes_path = card_dir / "modes"
        if modes_path.is_file():
            seen = set()
            try:
                for line in modes_path.read_text(encoding="utf-8").splitlines():
                    line = line.strip()
                    if line and line not in seen:
                        seen.add(line)
                        modes.append(line)
            except OSError:
                pass
        connectors.append({"connector": name, "connected": status == "connected", "modes": modes})
    return connectors


def action_list_displays(request):
    primary = device_env().get("ARMADA_PRIMARY_CONNECTOR", "")
    connectors = drm_connectors()
    for c in connectors:
        c["internal"] = c["connector"] == primary
    return {"connectors": connectors, "primaryConnector": primary}


def _display_remembered():
    try:
        data = json.loads(DISPLAY_REMEMBERED_PATH.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return {}
    return data if isinstance(data, dict) else {}


def action_get_display_config(request):
    remembered = _display_remembered()
    if not DISPLAY_OVERRIDE_PATH.exists():
        return {"useExternal": False, "remembered": remembered}
    values = {}
    try:
        for line in DISPLAY_OVERRIDE_PATH.read_text(encoding="utf-8").splitlines():
            if "=" in line:
                key, value = line.split("=", 1)
                values[key] = value
    except OSError:
        return {"useExternal": False, "remembered": remembered}
    return {
        "useExternal": True,
        "connector": values.get("ARMADA_DISPLAY_CONNECTOR", ""),
        "width": int(values.get("ARMADA_DISPLAY_WIDTH") or 0),
        "height": int(values.get("ARMADA_DISPLAY_HEIGHT") or 0),
        "orientation": values.get("ARMADA_DISPLAY_ORIENTATION", "normal"),
        "remembered": remembered,
    }


def action_set_display_config(request):
    if not bool(request.get("useExternal")):
        # Only the active choice is cleared - the remembered per-connector
        # settings survive so picking the same monitor later restores them.
        try:
            DISPLAY_OVERRIDE_PATH.unlink()
        except FileNotFoundError:
            pass
        return {"ok": True}

    connector = str(request.get("connector", ""))
    orientation = str(request.get("orientation", "normal"))
    if not re.fullmatch(r"[A-Za-z0-9_-]+", connector):
        raise ValueError("invalid connector")
    if orientation not in DISPLAY_ORIENTATIONS:
        raise ValueError("invalid orientation")
    try:
        width = int(request.get("width"))
        height = int(request.get("height"))
    except (TypeError, ValueError):
        raise ValueError("invalid resolution")
    if not (0 < width <= 16384 and 0 < height <= 16384):
        raise ValueError("invalid resolution")

    text = (
        f"ARMADA_DISPLAY_CONNECTOR={connector}\n"
        f"ARMADA_DISPLAY_WIDTH={width}\n"
        f"ARMADA_DISPLAY_HEIGHT={height}\n"
        f"ARMADA_DISPLAY_ORIENTATION={orientation}\n"
    )
    atomic_write(DISPLAY_OVERRIDE_PATH, text)
    remembered = _display_remembered()
    remembered[connector] = {"width": width, "height": height, "orientation": orientation}
    atomic_write(DISPLAY_REMEMBERED_PATH, json.dumps(remembered, separators=(",", ":")))
    return {"ok": True}


def action_restart_gamescope_session(request):
    # Output connector/resolution/rotation are gamescope startup flags (see
    # sessions.d/steam) - applying a new display choice needs the session
    # relaunched, not just the config file rewritten. Shared with
    # armada-display-hotplug's disconnect fallback (see that script's own
    # comment, and restart-gamescope-session's, for why this can't just be
    # session-control's switch-gamemode).
    run(["/usr/libexec/armada/restart-gamescope-session"], timeout=15)
    return {"ok": True}


