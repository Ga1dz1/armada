PARAM_SPECS = {
    "speed": {"min": 0.25, "max": 3.0, "default": 1.0, "modes": ("breathing", "spin", "rainbow", "multidot", "ambilight", "duotone", "wave", "starlight")},
    "intensity": {"min": 0.0, "max": 0.5, "default": 0.15, "modes": ("breathing", "spin", "multidot", "reactive", "duotone", "starlight")},
    "size": {"min": 1, "max": 3, "default": 2, "modes": ("spin", "multidot", "reactive")},
}


def param_key(param, mode):
    spec = PARAM_SPECS[param]
    return mode if mode in spec["modes"] else None


def get_param(settings, param, mode):
    spec = PARAM_SPECS[param]
    key = param_key(param, mode)
    return settings.get(f"{param}_{key}", spec["default"]) if key else spec["default"]


def clamp_param(param, value):
    spec = PARAM_SPECS[param]
    return max(spec["min"], min(spec["max"], value))


# --- reactive mode: raw gamepad evdev reader -------------------------------
# Raw gamepad MCU device name, checked against /sys/class/input/event*/device/name.
# Devices sharing the HTR3212 stick RGB hardware use different gamepad
# drivers/MCUs depending on family: Retroid Pocket Mini V2/5/Flip2 use the
# "retroid-gamepad" driver (reports "Retroid Pocket Gamepad"); Retroid Pocket
# 6 shares its InputPlumber composite device config with the AYN family and
# uses the "rsinput" driver instead, reporting "AYN Odin2 Gamepad" even on
# Retroid-branded hardware (confirmed on real Retroid Pocket 6 hardware) -
# unverified whether AYN Odin 2/Mini/Portal/Thor report this same exact
# string or their own variant.
GAMEPAD_NAMES = ("Retroid Pocket Gamepad", "AYN Odin2 Gamepad")
EV_KEY = 0x01
EV_ABS = 0x03
ABS_X, ABS_Y, ABS_RX, ABS_RY = 0x00, 0x01, 0x03, 0x04
INPUT_EVENT_FMT = "llHHi"  # 64-bit timeval (aarch64) + type + code + value
INPUT_EVENT_SIZE = struct.calcsize(INPUT_EVENT_FMT)
FLASH_DECAY = 0.72
FLASH_DEFAULT_COLOR = "FFFFFF"
# Raw BTN_* codes (linux/input-event-codes.h) mapped to the same logical
# button names InputPlumber's retroid_mcu.yaml capability map translates
# them to (including its North/West swap - BTN_NORTH really is wired to the
# "West" gamepad button and vice versa on this MCU), so a button's flash
# color lines up with whatever Steam itself calls that button. Anything not
# listed here (e.g. BTN_MODE/Guide, or a code we don't recognize) falls into
# the shared "other" bucket.
FLASH_BUTTON_CODES = {
    0x130: "south",       # BTN_SOUTH
    0x131: "east",        # BTN_EAST
    0x132: "r4",          # BTN_C -> RightPaddle1
    0x133: "west",        # BTN_NORTH -> gamepad West (see comment above)
    0x134: "north",       # BTN_WEST -> gamepad North (see comment above)
    0x135: "l4",          # BTN_Z -> LeftPaddle1
    0x136: "l1",          # BTN_TL -> LeftBumper
    0x137: "r1",          # BTN_TR -> RightBumper
    0x13a: "select",      # BTN_SELECT
    0x13b: "start",       # BTN_START
    0x13d: "l3",          # BTN_THUMBL -> LeftStick click
    0x13e: "r3",          # BTN_THUMBR -> RightStick click
    0x220: "dpad_up",      # BTN_DPAD_UP
    0x221: "dpad_down",    # BTN_DPAD_DOWN
    0x222: "dpad_left",    # BTN_DPAD_LEFT
    0x223: "dpad_right",   # BTN_DPAD_RIGHT
}
FLASH_BUTTONS = (
    "south", "east", "north", "west",
    "l1", "r1", "l3", "r3", "l4", "r4",
    "start", "select",
    "dpad_up", "dpad_down", "dpad_left", "dpad_right",
    "other",
)


def _eviocgabs(code):
    # _IOR('E', 0x40 + code, struct input_absinfo) - 6 x __s32 = 24 bytes.
    _IOC_READ = 2
    return (_IOC_READ << 30) | (24 << 16) | (ord("E") << 8) | (0x40 + code)


def gamepad_device_path():
    try:
        entries = Path("/sys/class/input").glob("event*")
    except OSError:
        return None
    for d in entries:
        try:
            if (d / "device" / "name").read_text().strip() in GAMEPAD_NAMES:
                return Path("/dev/input") / d.name
        except OSError:
            continue
    return None


class ReactiveInput:
    """Non-exclusive raw evdev reader for the gamepad's raw MCU device -
    InputPlumber keeps reading the same node concurrently for real input
    (passthrough: true on its source device, see 01-retroid-controller.yaml),
    this is just an extra open() for LED purposes, never EVIOCGRAB'd."""

    def __init__(self):
        self.fd = None
        self.ranges = {}
        self.lx = self.ly = self.rx = self.ry = 0.0
        self.flash = 0.0
        self.flash_button = "other"

    def ensure_open(self):
        if self.fd is not None:
            return True
        path = gamepad_device_path()
        if path is None:
            return False
        try:
            fd = os.open(str(path), os.O_RDONLY | os.O_NONBLOCK)
        except OSError:
            return False
        self.fd = fd
        self.ranges = {}
        for code in (ABS_X, ABS_Y, ABS_RX, ABS_RY):
            buf = bytearray(24)
            try:
                fcntl.ioctl(fd, _eviocgabs(code), buf)
                _, minimum, maximum, _, _, _ = struct.unpack("iiiiii", buf)
                if maximum > minimum:
                    self.ranges[code] = (minimum, maximum)
            except OSError:
                pass
        return True

    def close(self):
        if self.fd is not None:
            try:
                os.close(self.fd)
            except OSError:
                pass
            self.fd = None

    def _normalize(self, code, value):
        lo, hi = self.ranges.get(code, (-32768, 32767))
        span = (hi - lo) or 1
        return max(-1.0, min(1.0, (2 * (value - lo) / span) - 1))

    def poll(self):
        if not self.ensure_open():
            return
        try:
            while select.select([self.fd], [], [], 0)[0]:
                chunk = os.read(self.fd, INPUT_EVENT_SIZE)
                if len(chunk) != INPUT_EVENT_SIZE:
                    break
                _, _, ev_type, code, value = struct.unpack(INPUT_EVENT_FMT, chunk)
                if ev_type == EV_ABS:
                    if code == ABS_X:
                        self.lx = self._normalize(code, value)
                    elif code == ABS_Y:
                        self.ly = self._normalize(code, value)
                    elif code == ABS_RX:
                        self.rx = self._normalize(code, value)
                    elif code == ABS_RY:
                        self.ry = self._normalize(code, value)
                elif ev_type == EV_KEY and value == 1:
                    self.flash = 1.0
                    self.flash_button = FLASH_BUTTON_CODES.get(code, "other")
        except OSError:
            self.close()

    def tick_decay(self):
        self.flash *= FLASH_DECAY
        if self.flash < 0.02:
            self.flash = 0.0


REACTIVE_DEADZONE = 0.12  # below this magnitude, treat the stick as centered/idle (off)


def stick_reactive_rgb(x, y, floor):
    magnitude = min(1.0, math.hypot(x, y))
    if magnitude < REACTIVE_DEADZONE:
        return (0.0, 0.0, 0.0)
    hue = (math.atan2(y, x) % (2 * math.pi)) / (2 * math.pi)
    travel = (magnitude - REACTIVE_DEADZONE) / (1.0 - REACTIVE_DEADZONE)
    level = floor + (1 - floor) * travel
    return tuple(c * 255 * level for c in colorsys.hsv_to_rgb(hue, 1.0, 1.0))


# --- ambilight mode: DRM framebuffer color sampling ------------------------
# Each stick sits below and to its own side of the panel, not behind the
# whole screen, so this samples a strip near each screen edge instead of
# averaging everything: skip a small margin in from the edge (in case of a
# letterboxed/bezel-masked black border), take a band of pixels beyond that,
# and only look at the lower part of the screen's height (top ~40% is too far
# from either stick to feel connected to it; the very bottom ~5% is often a
# HUD/taskbar strip that isn't representative of "what's on screen"). These
# are screen-position constants, not per-device ones, because only one
# device is supported so far - if a second one needs different numbers this
# should move into device-env instead of growing per-device branches here.
# This SoC's DRM card is not reliably numbered /dev/dri/card0 (confirmed on
# real hardware it's card1, with no card0 node at all), so the right node is
# found at runtime instead of hardcoded.
AMBILIGHT_HWDOWNLOAD_FORMAT = "x2rgb10le"  # this Adreno/msm driver's native scanout
# format (confirmed via `ffmpeg -loglevel verbose ... kmsgrab`) - hwdownload
# fails outright if told to target anything else (tried bgr0 and nv12
# directly; both rejected). A separate `format=bgr0` step after hwdownload
# does the actual software pixel conversion.
AMBILIGHT_CAPTURE_FPS = 2  # fixed ffmpeg output rate - see AmbilightSampler docstring
AMBILIGHT_SMOOTHING = 0.35  # fraction of the way to the new sample each time, at speed=1.0
AMBILIGHT_GRID = 4  # downscale each side's sampled strip to this many pixels per side
AMBILIGHT_EDGE_MARGIN_PX = 10  # skip this many pixels in from the left/right screen edge
AMBILIGHT_EDGE_WIDTH_PX = 100  # sample this many pixels beyond the margin
AMBILIGHT_TOP_EXCLUDE = 0.40  # fraction of screen height excluded from the top
AMBILIGHT_BOTTOM_EXCLUDE = 0.05  # fraction of screen height excluded from the bottom
AMBILIGHT_DEFAULT = (0, 80, 255)
# DISABLED 2026-07-23: confirmed live that this daemon's own kmsgrab
# capture (running as root, on the SAME primary DRM node gamescope needs
# for its own atomic commits) can wedge gamescope's rendering entirely -
# drmModeAtomicCommit started failing with EACCES continuously (over
# 1000/min) the moment ambilight mode was active on a real device, dropping
# off within seconds of switching a stick away from it, and gamescope
# needed a full session restart to recover cleanly even after that.
# kmsgrab and an active compositor both wanting the primary node's
# mode-setting state is a real architectural conflict on this msm/DPU
# driver, not something a flag/tuning fixes - ambilight mode falls back to
# AMBILIGHT_DEFAULT (a static color) until this has a compositor-safe
# capture path instead (e.g. gamescope's own screencopy protocol or a
# PipeWire portal), rather than raw kmsgrab.
AMBILIGHT_CAPTURE_DISABLED = True
AMBILIGHT_FRAME_SIZE = 2 * AMBILIGHT_GRID * AMBILIGHT_GRID * 4  # bgr0 bytes per output frame
# This device's panel is mounted portrait; gamescope is launched with
# --force-orientation right --use-rotation-shader to correct for it on the
# way to the display, but kmsgrab grabs the raw scanout buffer *before* that
# correction, so the "left"/"right" edges below are meaningless without first
# undoing it. Confirmed empirically: captured a frame, compared against a
# known on-screen landmark (clock/battery, top-right as worn), and
# ffmpeg's transpose=2 (90 deg counter-clockwise) is what makes the capture
# upright and match it. Unlike the LED zone numbering elsewhere in this file
# (a fact about the HTR3212 wiring, true for any device with these same
# zones), this is purely about *this panel's* mounting - a future device
# with the same RGB stick hardware but a differently-oriented or
# already-landscape-native panel would need a different value here, or none.
AMBILIGHT_SCANOUT_TRANSPOSE = 2


def cmd_test_zones():
    """Light each LED zone individually (~1.5s each, white) so someone can
    read off the physical zone-to-position mapping by eye instead of poking
    sysfs by hand - stops the daemon first since it would otherwise fight
    over the same LEDs, and restarts it on the way out."""
    subprocess.run(["systemctl", "stop", "armada-stick-led"], check=False)
    try:
        for s in SIDES:
            for z in ZONES:
                write_zone(s, z, 0, 0, 0)
        for side in SIDES:
            for zone in ZONES:
                for s in SIDES:
                    for z in ZONES:
                        write_zone(s, z, 0, 0, 0)
                print(f"{side}:{zone}", flush=True)
                write_zone(side, zone, 200, 200, 200)
                time.sleep(1.5)
        for s in SIDES:
            for z in ZONES:
                write_zone(s, z, 0, 0, 0)
    finally:
        subprocess.run(["systemctl", "start", "armada-stick-led"], check=False)
    return 0


def cmd_test_ambilight(seconds):
    """Print the sampled left/right ambilight colors once a second so
    someone can watch the numbers next to the physical screen and stick to
    confirm the capture is reading the intended edge - the sanity check for
    AMBILIGHT_SCANOUT_TRANSPOSE and the crop constants above it, without
    needing a developer session to re-derive it by hand."""
    sampler = AmbilightSampler()
    try:
        end = time.time() + seconds
        while time.time() < end:
            color_l, color_r = sampler.sample(1.0, 1.0)
            l = tuple(round(c) for c in color_l)
            r = tuple(round(c) for c in color_r)
            print(f"L={l}  R={r}", flush=True)
            time.sleep(1.0)
    finally:
        sampler.close()
    return 0


def drm_card_path():
    try:
        cards = sorted(Path("/dev/dri").glob("card*"))
    except OSError:
        return None
    return str(cards[0]) if cards else None


def _ambilight_filter():
    m, w = AMBILIGHT_EDGE_MARGIN_PX, AMBILIGHT_EDGE_WIDTH_PX
    y = f"ih*{AMBILIGHT_TOP_EXCLUDE}"
    h = f"ih*{1.0 - AMBILIGHT_TOP_EXCLUDE - AMBILIGHT_BOTTOM_EXCLUDE}"
    g = AMBILIGHT_GRID
    return (
        f"hwdownload,format={AMBILIGHT_HWDOWNLOAD_FORMAT},format=bgr0,"
        f"transpose={AMBILIGHT_SCANOUT_TRANSPOSE},"
        f"split=2[a][b];"
        f"[a]crop=w={w}:h={h}:x={m}:y={y},scale={g}:{g}[left];"
        f"[b]crop=w={w}:h={h}:x=iw-{m}-{w}:y={y},scale={g}:{g}[right];"
        f"[left][right]hstack=inputs=2[out]"
    )


def _average_region(data, width, x0, x1, y0, y1):
    tr = tg = tb = 0.0
    n = 0
    for y in range(y0, y1):
        row = y * width
        for x in range(x0, x1):
            off = (row + x) * 4
            tb += data[off]
            tg += data[off + 1]
            tr += data[off + 2]
            n += 1
    return (tr / n, tg / n, tb / n) if n else None


class AmbilightSampler:
    """Keeps a single ffmpeg kmsgrab process alive in the background rather
    than spawning a fresh one per sample - process startup (dynamic linking,
    opening the DRM card, allocating capture buffers) is the dominant cost
    here, not the capture itself, so this amortizes that cost across the
    whole time ambilight mode stays selected instead of paying it on every
    single sample. ffmpeg runs at a fixed, modest output rate regardless of
    the "speed" param; speed instead controls how aggressively each side's
    LED color chases its own incoming sample (see sample()) - independent
    per side since each stick can have its own speed now - which is the more
    perceptually relevant knob for a slow ambient effect like this anyway."""

    def __init__(self):
        self.color_l = AMBILIGHT_DEFAULT
        self.color_r = AMBILIGHT_DEFAULT
        self.proc = None
        self.buf = b""

    def ensure_open(self):
        if AMBILIGHT_CAPTURE_DISABLED:
            return False
        if self.proc is not None and self.proc.poll() is None:
            return True
        self.close()
        card = drm_card_path()
        if card is None:
            return False
        try:
            self.proc = subprocess.Popen(
                [
                    "ffmpeg", "-hide_banner", "-loglevel", "error",
                    "-f", "kmsgrab", "-device", card, "-i", "-",
                    "-r", str(AMBILIGHT_CAPTURE_FPS),
                    "-filter_complex", _ambilight_filter(),
                    "-map", "[out]",
                    "-f", "rawvideo", "-pix_fmt", "bgr0", "-",
                ],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                stdin=subprocess.DEVNULL,
            )
        except OSError:
            self.proc = None
            return False
        os.set_blocking(self.proc.stdout.fileno(), False)
        self.buf = b""
        return True

    def close(self):
        if self.proc is not None:
            try:
                self.proc.kill()
                self.proc.wait(timeout=1)
            except (OSError, subprocess.TimeoutExpired):
                pass
            self.proc = None
        self.buf = b""

    def sample(self, speed_l, speed_r):
        if not self.ensure_open():
            return self.color_l, self.color_r
        try:
            while True:
                chunk = os.read(self.proc.stdout.fileno(), 65536)
                if not chunk:
                    self.close()
                    return self.color_l, self.color_r
                self.buf += chunk
        except BlockingIOError:
            pass
        except OSError:
            self.close()
            return self.color_l, self.color_r
        n_frames = len(self.buf) // AMBILIGHT_FRAME_SIZE
        if n_frames == 0:
            return self.color_l, self.color_r
        # Only the newest complete frame matters - if the daemon fell behind,
        # older buffered frames are already stale.
        frame = self.buf[(n_frames - 1) * AMBILIGHT_FRAME_SIZE : n_frames * AMBILIGHT_FRAME_SIZE]
        self.buf = self.buf[n_frames * AMBILIGHT_FRAME_SIZE :]
        g = AMBILIGHT_GRID
        left = _average_region(frame, 2 * g, 0, g, 0, g)
        right = _average_region(frame, 2 * g, g, 2 * g, 0, g)
        if left is None or right is None:
            return self.color_l, self.color_r
        smoothing_l = min(0.9, AMBILIGHT_SMOOTHING * speed_l)
        smoothing_r = min(0.9, AMBILIGHT_SMOOTHING * speed_r)
        self.color_l = tuple(c * (1 - smoothing_l) + t * smoothing_l for c, t in zip(self.color_l, left))
        self.color_r = tuple(c * (1 - smoothing_r) + t * smoothing_r for c, t in zip(self.color_r, right))
        return self.color_l, self.color_r


def _default_side_state():
    return {
        "mode": DEFAULT_MODE,
        "color": DEFAULT_COLOR,
        "color_source": DEFAULT_COLOR_SOURCE,
        "charging_indicator": DEFAULT_CHARGING_INDICATOR,
        "settings": {},
        "duotone_color_a": DEFAULT_DUOTONE_COLOR_A,
        "duotone_color_b": DEFAULT_DUOTONE_COLOR_B,
        "duotone_orientation": DEFAULT_DUOTONE_ORIENTATION,
        # Toggles on a base mode rather than separate MODES entries - see
        # MODES's own comment.
        "chase": False,     # spin: soft trailing dot (apply_chase) instead of a hard single dot
        "compass": False,   # reactive: point at push direction instead of lighting uniformly
        "seesaw": False,    # duotone: breathe the two color groups against each other
    }


def load_state():
    state = {
        "l": _default_side_state(),
        "r": _default_side_state(),
        "screen_link": DEFAULT_SCREEN_LINK,
        "enabled": DEFAULT_ENABLED,
        "flash_colors": {},
    }
    try:
        lines = CONFIG.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return state
    for line in lines:
        key, sep, raw = line.partition("=")
        if not sep:
            continue
        key, raw = key.strip(), raw.strip()
        if key == "screen_link":
            state["screen_link"] = raw == "1"
            continue
        if key == "enabled":
            state["enabled"] = raw == "1"
            continue
        if key.startswith("flash_") and key[len("flash_"):] in FLASH_BUTTONS:
            if re.fullmatch(r"[0-9A-Fa-f]{6}", raw or ""):
                state["flash_colors"][key[len("flash_"):]] = raw.upper()
            continue
        if key.endswith("_l"):
            side, base = "l", key[:-2]
        elif key.endswith("_r"):
            side, base = "r", key[:-2]
        else:
            continue
        s = state[side]
        if base == "mode":
            if raw in MODES:
                s["mode"] = raw
            # Migrate configs saved before color_source existed - battery
            # coloring used to be its own mode instead of a source any mode
            # can use, and alternating had no direct replacement once modes
            # became independent per side (see the docstring's Removed
            # note), so it just falls back to the default (static).
            elif raw == "battery":
                s["mode"] = "static"
                s["color_source"] = "battery"
            elif raw == "battery-breathing":
                s["mode"] = "breathing"
                s["color_source"] = "battery"
            # "chase" was its own mode before it became a toggle on "spin"
            # (same ring position/speed, just apply_chase's falloff instead
            # of apply_spin's hard edge) - carry old configs forward.
            elif raw == "chase":
                s["mode"] = "spin"
                s["chase"] = True
        elif base == "color" and re.fullmatch(r"[0-9A-Fa-f]{6}", raw or ""):
            s["color"] = raw
        elif base == "color_source" and raw in COLOR_SOURCES:
            s["color_source"] = raw
        elif base == "charging_indicator":
            s["charging_indicator"] = raw == "1"
        elif base == "chase":
            s["chase"] = raw == "1"
        elif base == "compass":
            s["compass"] = raw == "1"
        elif base == "seesaw":
            s["seesaw"] = raw == "1"
        elif base == "duotone_color_a" and re.fullmatch(r"[0-9A-Fa-f]{6}", raw or ""):
            s["duotone_color_a"] = raw.upper()
        elif base == "duotone_color_b" and re.fullmatch(r"[0-9A-Fa-f]{6}", raw or ""):
            s["duotone_color_b"] = raw.upper()
        elif base == "duotone_orientation" and raw in DUOTONE_ORIENTATIONS:
            s["duotone_orientation"] = raw
        elif "_" in base and base.split("_", 1)[0] in PARAM_SPECS:
            try:
                s["settings"][base] = float(raw)
            except ValueError:
                pass
    return state


def save_state(state):
    CONFIG.parent.mkdir(parents=True, exist_ok=True)
    lines = [
        f"screen_link={'1' if state['screen_link'] else '0'}",
        f"enabled={'1' if state.get('enabled', True) else '0'}",
    ]
    for side in SIDES:
        s = state[side]
        lines.append(f"mode_{side}={s['mode']}")
        lines.append(f"color_{side}={s['color']}")
        lines.append(f"color_source_{side}={s['color_source']}")
        lines.append(f"charging_indicator_{side}={'1' if s['charging_indicator'] else '0'}")
        lines.append(f"duotone_color_a_{side}={s['duotone_color_a']}")
        lines.append(f"duotone_color_b_{side}={s['duotone_color_b']}")
        lines.append(f"duotone_orientation_{side}={s['duotone_orientation']}")
        lines.append(f"chase_{side}={'1' if s['chase'] else '0'}")
        lines.append(f"compass_{side}={'1' if s['compass'] else '0'}")
        lines.append(f"seesaw_{side}={'1' if s['seesaw'] else '0'}")
        for key in sorted(s["settings"]):
            lines.append(f"{key}_{side}={s['settings'][key]:.3f}")
    for button in sorted(state["flash_colors"]):
        lines.append(f"flash_{button}={state['flash_colors'][button]}")
    tmp = CONFIG.with_name(f".{CONFIG.name}.tmp")
    tmp.write_text("\n".join(lines) + "\n", encoding="utf-8")
    tmp.chmod(0o644)
    tmp.replace(CONFIG)


def flash_color_rgb(flash_colors, button):
    hex_color = flash_colors.get(button, FLASH_DEFAULT_COLOR)
    return int(hex_color[0:2], 16), int(hex_color[2:4], 16), int(hex_color[4:6], 16)


def screen_scale():
    try:
        devices = sorted(BACKLIGHT_BASE.glob("*"))
    except OSError:
        return 1.0
    for bl in devices:
        try:
            current = int((bl / "brightness").read_text().strip())
            maximum = int((bl / "max_brightness").read_text().strip())
        except (OSError, ValueError):
            continue
        if maximum > 0:
            return max(0.0, min(1.0, current / maximum))
    return 1.0


def _gamma_correct(value):
    # HTR3212's brightness_set writes the raw value straight to the PWM
    # duty-cycle register with zero correction of its own (confirmed in
    # armada-packages' 0033_leds--Add-driver-for-HEROIC-HTR3212.patch), so a
    # linear 0-255 value looks nothing like a linear perceived brightness -
    # anything dimmed (screen_link's scale, a mode's intensity floor, a
    # chase/multidot fade tail) comes out pale and hue-shifted instead of
    # just dimmer, since 8-bit rounding distorts a small channel's value
    # much more than a large one. Standard LED gamma fixes both: it lifts
    # the dim end of the curve (so low values round more precisely) while
    # leaving the endpoints fixed (0->0, 255->255), so full-brightness
    # colors are completely unaffected.
    v = max(0.0, min(255.0, value)) / 255.0
    return (v ** LED_GAMMA) * 255.0


def write_zone(side, zone, r, g, b):
    ok = False
    for chan, val in (("r", r), ("g", g), ("b", b)):
        led = LED_BASE / f"{side}:{chan}{zone}" / "brightness"
        try:
            led.write_text(str(max(0, min(255, int(round(_gamma_correct(val)))))))
            ok = True
        except OSError:
            pass
    return ok


def apply_rgb(r, g, b):
    ok = False
    for side in SIDES:
        for zone in ZONES:
            if write_zone(side, zone, r, g, b):
                ok = True
    return ok


def apply_side_rgb(side, r, g, b):
    ok = False
    for zone in ZONES:
        if write_zone(side, zone, r, g, b):
            ok = True
    return ok


def apply_chase(side, r, g, b, pos, scale, size, floor):
    ok = False
    for idx, zone in enumerate(ZONES):
        dist = abs(idx - pos)
        dist = min(dist, len(ZONES) - dist)
        level = floor + (1 - floor) * max(0.0, 1.0 - dist / size)
        level *= scale
        if write_zone(side, zone, r * level, g * level, b * level):
            ok = True
    return ok


def apply_spin(side, r, g, b, pos, scale, floor):
    ok = False
    lit_idx = int(round(pos)) % len(ZONES)
    for idx, zone in enumerate(ZONES):
        level = (1.0 if idx == lit_idx else floor) * scale
        if write_zone(side, zone, r * level, g * level, b * level):
            ok = True
    return ok


def apply_charging_dot(side, scale):
    # Overlays ON TOP of whatever the side's normal render just wrote -
    # only the one zone currently "lit" changes, the other three are left
    # exactly as the base render (battery-color static/breathing/chase/
    # spin/etc.) put them. Position derived straight from wall-clock time
    # (not the daemon's own per-side anim state) so it stays a steady,
    # predictable 1 rev/sec regardless of which mode is doing the base
    # render or how fast that mode's own animation is going.
    zone_idx = int(time.time() * CHARGING_DOT_ZONES_PER_SEC * len(ZONES)) % len(ZONES)
    r, g, b = CHARGING_DOT_COLOR
    write_zone(side, ZONES[zone_idx], r * scale, g * scale, b * scale)


def apply_multidot(side, base_pos, scale, size, floor):
    ok = False
    spacing = len(ZONES) / len(MULTIDOT_COLORS)
    totals = [[0.0, 0.0, 0.0] for _ in ZONES]
    for i, (dr, dg, db) in enumerate(MULTIDOT_COLORS):
        dot_pos = (base_pos + i * spacing) % len(ZONES)
        for idx in range(len(ZONES)):
            dist = abs(idx - dot_pos)
            dist = min(dist, len(ZONES) - dist)
            level = floor + (1 - floor) * max(0.0, 1.0 - dist / size)
            totals[idx][0] += dr * level
            totals[idx][1] += dg * level
            totals[idx][2] += db * level
    for idx, zone in enumerate(ZONES):
        r, g, b = totals[idx]
        if write_zone(side, zone, r * scale, g * scale, b * scale):
            ok = True
    return ok


def apply_hex(side, hex_color, scale=1.0):
    r, g, b = int(hex_color[0:2], 16), int(hex_color[2:4], 16), int(hex_color[4:6], 16)
    return apply_side_rgb(side, r * scale, g * scale, b * scale)


def apply_duotone(side, color_a, color_b, orientation, scale=1.0):
    ok = False
    ar, ag, ab = int(color_a[0:2], 16), int(color_a[2:4], 16), int(color_a[4:6], 16)
    br, bg, bb = int(color_b[0:2], 16), int(color_b[2:4], 16), int(color_b[4:6], 16)
    zones_a, zones_b = DUOTONE_ZONE_GROUPS.get(orientation, DUOTONE_ZONE_GROUPS[DEFAULT_DUOTONE_ORIENTATION])
    for zone in zones_a:
        if write_zone(side, zone, ar * scale, ag * scale, ab * scale):
            ok = True
    for zone in zones_b:
        if write_zone(side, zone, br * scale, bg * scale, bb * scale):
            ok = True
    return ok


def battery_capacity_status():
    for supply in POWER_SUPPLY_BASE.glob("*"):
        try:
            if (supply / "type").read_text().strip() != "Battery":
                continue
            capacity = int((supply / "capacity").read_text().strip())
            status = (supply / "status").read_text().strip()
        except (OSError, ValueError):
            continue
        return capacity, status
    return None, None


def battery_gradient_rgb(capacity):
    if capacity is None:
        return 0, 80, 255  # no battery info - fall back to the default blue
    capacity = max(0, min(100, capacity))
    # Quantized so ordinary capacity-reading jitter doesn't visibly flicker
    # the color - see BATTERY_GRADIENT_STEP_PCT's own comment.
    step = round(capacity / BATTERY_GRADIENT_STEP_PCT) * BATTERY_GRADIENT_STEP_PCT
    if step <= BATTERY_RED_MAX_PCT:
        return 255, 0, 0
    if step <= BATTERY_YELLOW_PCT:
        t = (step - BATTERY_RED_MAX_PCT) / (BATTERY_YELLOW_PCT - BATTERY_RED_MAX_PCT)
        return 255, int(255 * t), 0
    t = (step - BATTERY_YELLOW_PCT) / (100 - BATTERY_YELLOW_PCT)
    return int(255 * (1 - t)), 255, 0


def is_charging():
    _, status = battery_capacity_status()
    return status == "Charging"


def base_rgb(color, color_source):
    if color_source == "battery":
        capacity, _ = battery_capacity_status()
        return battery_gradient_rgb(capacity)
    if color_source == "random":
        # No anim/tick state available here (this is the one-shot snapshot
        # path - apply_current(), render_side_static() with anim=None) - a
        # fresh random hue each call is fine since "random" forces the
        # daemon into its continuously-ticking path (see run_daemon), where
        # random_step_rgb() below is used instead for a smooth shift.
        return tuple(c * 255 for c in colorsys.hsv_to_rgb(random.random(), 1.0, 1.0))
    return int(color[0:2], 16), int(color[2:4], 16), int(color[4:6], 16)


def random_step_rgb(anim):
    state = anim.setdefault("random", {"hue": random.random(), "target": random.random(), "next_change": 0.0})
    now = time.time()
    if now >= state["next_change"]:
        state["target"] = random.random()
        state["next_change"] = now + RANDOM_COLOR_CHANGE_INTERVAL_S
    # Shortest-path hue interpolation, wrapping around the hue circle.
    diff = (state["target"] - state["hue"] + 0.5) % 1.0 - 0.5
    state["hue"] = (state["hue"] + diff * RANDOM_COLOR_SMOOTHING) % 1.0
    return tuple(c * 255 for c in colorsys.hsv_to_rgb(state["hue"], 1.0, 1.0))


def shimmer_rgb(color, anim):
    h, l, _s = colorsys.rgb_to_hls(int(color[0:2], 16) / 255, int(color[2:4], 16) / 255, int(color[4:6], 16) / 255)
    phase = anim.get("shimmer_phase", 0.0)
    t = 0.5 + 0.5 * math.sin(phase)  # 0 = pale/cold, 1 = saturated/warm
    saturation = SHIMMER_COOL_SATURATION + (SHIMMER_WARM_SATURATION - SHIMMER_COOL_SATURATION) * t
    hue = (h - SHIMMER_HUE_SWING * (t - 0.5) * 2) % 1.0
    anim["shimmer_phase"] = (phase + SHIMMER_PHASE_STEP) % (2 * math.pi)
    return tuple(c * 255 for c in colorsys.hls_to_rgb(hue, l, saturation))


def resolve_base_rgb(color, color_source, anim=None):
    if anim is not None:
        if color_source == "random":
            return random_step_rgb(anim)
        if color_source == "shimmer":
            return shimmer_rgb(color, anim)
    return base_rgb(color, color_source)


def rainbow_rgb(phase):
    hue = (phase % (2 * math.pi)) / (2 * math.pi)
    return tuple(c * 255 for c in colorsys.hsv_to_rgb(hue, 1.0, 1.0))


def apply_current():
    state = load_state()
    if not state.get("enabled", True):
        return apply_rgb(0, 0, 0)
    scale = screen_scale() if state["screen_link"] else 1.0
    charging = is_charging()
    ok = False
    for side in SIDES:
        s = state[side]
        mode, color, color_source = s["mode"], s["color"], s["color_source"]
        if mode == "duotone":
            if apply_duotone(side, s["duotone_color_a"], s["duotone_color_b"], s["duotone_orientation"], scale):
                ok = True
            continue
        r, g, b = rainbow_rgb(0.0) if mode == "rainbow" else base_rgb(color, color_source)
        if apply_side_rgb(side, r * scale, g * scale, b * scale):
            ok = True
        if color_source == "battery" and charging and s["charging_indicator"]:
            apply_charging_dot(side, scale)
    return ok


def _new_anim():
    return {"phase": 0.0, "chase_pos": 0.0, "multidot_pos": 0.0, "starlight": [0.0] * len(ZONES)}


def _maybe_charging_dot(side, s, scale, charging):
    if s["color_source"] == "battery" and charging and s["charging_indicator"]:
        apply_charging_dot(side, scale)


def render_side_static(side, s, scale, charging=None):
    mode, color, color_source = s["mode"], s["color"], s["color_source"]
    if mode == "duotone":
        apply_duotone(side, s["duotone_color_a"], s["duotone_color_b"], s["duotone_orientation"], scale)
        return
    r, g, b = base_rgb(color, color_source)
    apply_side_rgb(side, r * scale, g * scale, b * scale)
    _maybe_charging_dot(side, s, scale, charging if charging is not None else is_charging())


def render_side_animated(side, s, scale, anim, reactive, ambilight_colors, flash_colors, charging):
    mode, color, color_source, settings = s["mode"], s["color"], s["color_source"], s["settings"]
    if mode == "duotone" and s.get("seesaw"):
        zones_a, zones_b = DUOTONE_ZONE_GROUPS.get(s["duotone_orientation"], DUOTONE_ZONE_GROUPS[DEFAULT_DUOTONE_ORIENTATION])
        ar, ag, ab = int(s["duotone_color_a"][0:2], 16), int(s["duotone_color_a"][2:4], 16), int(s["duotone_color_a"][4:6], 16)
        br, bg, bb = int(s["duotone_color_b"][0:2], 16), int(s["duotone_color_b"][2:4], 16), int(s["duotone_color_b"][4:6], 16)
        floor = get_param(settings, "intensity", "duotone")
        t = 0.5 + 0.5 * math.sin(anim["phase"])
        level_a, level_b = floor + (1 - floor) * t, floor + (1 - floor) * (1 - t)
        for zone in zones_a:
            write_zone(side, zone, ar * level_a * scale, ag * level_a * scale, ab * level_a * scale)
        for zone in zones_b:
            write_zone(side, zone, br * level_b * scale, bg * level_b * scale, bb * level_b * scale)
        anim["phase"] = (anim["phase"] + BASE_BREATH_STEP * get_param(settings, "speed", "duotone")) % (2 * math.pi)
        _maybe_charging_dot(side, s, scale, charging)
        return
    if mode not in ANIMATED_MODES and color_source not in ("random", "shimmer"):
        render_side_static(side, s, scale, charging)
        return
    # Charging dot rides on top of the base render's current brightness by
    # default (only breathing actually varies it over time - everything
    # else here is already at full brightness*scale on every tick) so it
    # doesn't look like a static blue LED stuck mid-pulse while the rest of
    # the stick visibly breathes around it.
    dot_scale = scale
    if mode == "rainbow":
        r, g, b = rainbow_rgb(anim["phase"])
        apply_side_rgb(side, r * scale, g * scale, b * scale)
        anim["phase"] = (anim["phase"] + BASE_BREATH_STEP * get_param(settings, "speed", mode)) % (2 * math.pi)
    elif mode == "wave":
        for idx, zone in enumerate(ZONES):
            r, g, b = rainbow_rgb(anim["phase"] + idx * WAVE_ZONE_HUE_STEP)
            write_zone(side, zone, r * scale, g * scale, b * scale)
        anim["phase"] = (anim["phase"] + BASE_BREATH_STEP * get_param(settings, "speed", mode)) % (2 * math.pi)
    elif mode == "starlight":
        r, g, b = resolve_base_rgb(color, color_source, anim)
        floor = get_param(settings, "intensity", mode)
        speed = get_param(settings, "speed", mode)
        levels = anim["starlight"]
        for idx, zone in enumerate(ZONES):
            if levels[idx] <= floor + 0.01 and random.random() < STARLIGHT_TRIGGER_CHANCE * speed:
                levels[idx] = 1.0
            else:
                levels[idx] = floor + (levels[idx] - floor) * STARLIGHT_DECAY
            level = levels[idx] * scale
            write_zone(side, zone, r * level, g * level, b * level)
    elif mode == "spin":
        r, g, b = resolve_base_rgb(color, color_source, anim)
        floor = get_param(settings, "intensity", mode)
        if s.get("chase"):
            size = get_param(settings, "size", mode)
            apply_chase(side, r, g, b, anim["chase_pos"], scale, size, floor)
        else:
            apply_spin(side, r, g, b, anim["chase_pos"], scale, floor)
        anim["chase_pos"] = (anim["chase_pos"] + SPIN_ZONES_PER_SEC * get_param(settings, "speed", mode) * BREATH_INTERVAL) % len(ZONES)
    elif mode == "multidot":
        size = get_param(settings, "size", mode)
        floor = get_param(settings, "intensity", mode)
        apply_multidot(side, anim["multidot_pos"], scale, size, floor)
        anim["multidot_pos"] = (anim["multidot_pos"] + MULTIDOT_ZONES_PER_SEC * get_param(settings, "speed", mode) * BREATH_INTERVAL) % len(ZONES)
    elif mode == "reactive":
        floor = get_param(settings, "intensity", mode)
        x, y = (reactive.lx, -reactive.ly) if side == "l" else (reactive.rx, -reactive.ry)
        cr, cg, cb = stick_reactive_rgb(x, y, floor)
        flash = reactive.flash
        fr, fg, fb = flash_color_rgb(flash_colors, reactive.flash_button)
        blend = lambda c, f: c * (1 - flash) + f * flash  # noqa: E731
        r, g, b = blend(cr, fr), blend(cg, fg), blend(cb, fb)
        if s.get("compass"):
            size = get_param(settings, "size", mode)
            pos = angle_to_chase_pos(math.atan2(y, x))
            apply_chase(side, r, g, b, pos, scale, size, floor)
        else:
            apply_side_rgb(side, r * scale, g * scale, b * scale)
    elif mode == "ambilight":
        color3 = ambilight_colors[0] if side == "l" else ambilight_colors[1]
        apply_side_rgb(side, color3[0] * scale, color3[1] * scale, color3[2] * scale)
    elif mode == "static":
        # Only reached here at all when color_source is "random" or
        # "shimmer" (static otherwise isn't in ANIMATED_MODES) - no
        # breathing envelope, just the color_source's own animation at full
        # brightness.
        r, g, b = resolve_base_rgb(color, color_source, anim)
        apply_side_rgb(side, r * scale, g * scale, b * scale)
    else:
        r, g, b = resolve_base_rgb(color, color_source, anim)
        floor = get_param(settings, "intensity", mode)
        level = scale * (floor + (1 - floor) * (0.5 + 0.5 * math.sin(anim["phase"])))
        apply_side_rgb(side, r * level, g * level, b * level)
        anim["phase"] = (anim["phase"] + BASE_BREATH_STEP * get_param(settings, "speed", mode)) % (2 * math.pi)
        dot_scale = level
    _maybe_charging_dot(side, s, dot_scale, charging)


def run_daemon():
    anim = {"l": _new_anim(), "r": _new_anim()}
    reactive = ReactiveInput()
    ambilight = AmbilightSampler()
    while True:
        if SUSPEND_FLAG.exists():
            reactive.close()
            ambilight.close()
            apply_rgb(0, 0, 0)
            anim = {"l": _new_anim(), "r": _new_anim()}
            time.sleep(SUSPEND_POLL_INTERVAL)
            continue
        state = load_state()
        if not state.get("enabled", True):
            reactive.close()
            ambilight.close()
            apply_rgb(0, 0, 0)
            anim = {"l": _new_anim(), "r": _new_anim()}
            time.sleep(IDLE_INTERVAL)
            continue
        scale = screen_scale() if state["screen_link"] else 1.0
        modes = {side: state[side]["mode"] for side in SIDES}
        used_reactive = "reactive" in modes.values()
        used_ambilight = "ambilight" in modes.values()
        if not used_reactive:
            reactive.close()
        if not used_ambilight:
            ambilight.close()
        charging = is_charging()
        # The charging indicator steps once a second - that needs the fast
        # tick even for an otherwise-static mode, or it'd only update once
        # per IDLE_INTERVAL and the "rotation" would just look like an
        # occasional jump.
        any_charging_dot = charging and any(
            state[side]["color_source"] == "battery" and state[side]["charging_indicator"] for side in SIDES
        )
        any_animated = (
            any_charging_dot
            or any(m in ANIMATED_MODES for m in modes.values())
            or any(state[side]["mode"] == "duotone" and state[side].get("seesaw") for side in SIDES)
            or any(state[side]["color_source"] in ("random", "shimmer") for side in SIDES)
        )
        if any_animated:
            if used_reactive:
                reactive.poll()
            ambilight_colors = None
            if used_ambilight:
                speed_l = get_param(state["l"]["settings"], "speed", "ambilight")
                speed_r = get_param(state["r"]["settings"], "speed", "ambilight")
                ambilight_colors = ambilight.sample(speed_l, speed_r)
            for side in SIDES:
                render_side_animated(side, state[side], scale, anim[side], reactive, ambilight_colors, state["flash_colors"], charging)
            if used_reactive:
                reactive.tick_decay()
            time.sleep(BREATH_INTERVAL)
        else:
            for side in SIDES:
                render_side_static(side, state[side], scale, charging)
            anim = {"l": _new_anim(), "r": _new_anim()}
            time.sleep(IDLE_INTERVAL if not state["screen_link"] else BREATH_INTERVAL * 4)


def print_state():
    state = load_state()
    print(f"screen_link={'1' if state['screen_link'] else '0'}")
    print(f"enabled={'1' if state.get('enabled', True) else '0'}")
    for side in SIDES:
        s = state[side]
        print(f"mode_{side}={s['mode']}")
        print(f"color_{side}={s['color']}")
        print(f"color_source_{side}={s['color_source']}")
        print(f"charging_indicator_{side}={'1' if s['charging_indicator'] else '0'}")
        print(f"duotone_color_a_{side}={s['duotone_color_a']}")
        print(f"duotone_color_b_{side}={s['duotone_color_b']}")
        print(f"duotone_orientation_{side}={s['duotone_orientation']}")
        for param in PARAM_SPECS:
            for m in PARAM_SPECS[param]["modes"]:
                print(f"{param}_{m}_{side}={get_param(s['settings'], param, m):.3f}")
    for button in FLASH_BUTTONS:
        print(f"flash_{button}={state['flash_colors'].get(button, FLASH_DEFAULT_COLOR)}")


def main(argv):
    command = argv[1] if len(argv) > 1 else "get"
    if command == "get":
        print_state()
        return 0
    if command == "set":
        if len(argv) != 4 or argv[2] not in SIDES or not re.fullmatch(r"[0-9A-Fa-f]{6}", argv[3]):
            print("usage: stick-led-color set <l|r> <RRGGBB hex>", file=sys.stderr)
            return 2
        side, value = argv[2], argv[3].upper()
        state = load_state()
        state[side]["mode"] = "static"
        state[side]["color"] = value
        # Picking an explicit color is a clear signal to stop tracking
        # battery level - otherwise it'd save but have no visible effect.
        state[side]["color_source"] = "static"
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-mode":
        if len(argv) != 4 or argv[2] not in SIDES or argv[3] not in MODES:
            print(f"usage: stick-led-color set-mode <l|r> <{'|'.join(MODES)}>", file=sys.stderr)
            return 2
        side, mode = argv[2], argv[3]
        state = load_state()
        state[side]["mode"] = mode
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-enabled":
        if len(argv) != 3 or argv[2] not in ("on", "off"):
            print("usage: stick-led-color set-enabled <on|off>", file=sys.stderr)
            return 2
        state = load_state()
        state["enabled"] = argv[2] == "on"
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-screen-link":
        if len(argv) != 3 or argv[2] not in ("on", "off"):
            print("usage: stick-led-color set-screen-link <on|off>", file=sys.stderr)
            return 2
        state = load_state()
        state["screen_link"] = argv[2] == "on"
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-param":
        if len(argv) != 6 or argv[2] not in SIDES or argv[3] not in PARAM_SPECS:
            print(f"usage: stick-led-color set-param <l|r> <{'|'.join(PARAM_SPECS)}> <mode> <value>", file=sys.stderr)
            return 2
        side, param, target_mode = argv[2], argv[3], argv[4]
        key = param_key(param, target_mode)
        if key is None:
            print(f"{param} does not apply to mode {target_mode}", file=sys.stderr)
            return 2
        try:
            value = clamp_param(param, float(argv[5]))
        except ValueError:
            print("invalid value", file=sys.stderr)
            return 2
        state = load_state()
        state[side]["settings"][f"{param}_{key}"] = value
        save_state(state)
        return 0
    if command == "set-color-source":
        if len(argv) != 4 or argv[2] not in SIDES or argv[3] not in COLOR_SOURCES:
            print(f"usage: stick-led-color set-color-source <l|r> <{'|'.join(COLOR_SOURCES)}>", file=sys.stderr)
            return 2
        side, source = argv[2], argv[3]
        state = load_state()
        state[side]["color_source"] = source
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-charging-indicator":
        if len(argv) != 4 or argv[2] not in SIDES or argv[3] not in ("on", "off"):
            print("usage: stick-led-color set-charging-indicator <l|r> <on|off>", file=sys.stderr)
            return 2
        side = argv[2]
        state = load_state()
        state[side]["charging_indicator"] = argv[3] == "on"
        save_state(state)
        return 0 if apply_current() else 1
    if command in ("set-chase", "set-compass", "set-seesaw"):
        key = command[len("set-"):]
        if len(argv) != 4 or argv[2] not in SIDES or argv[3] not in ("on", "off"):
            print(f"usage: stick-led-color {command} <l|r> <on|off>", file=sys.stderr)
            return 2
        side = argv[2]
        state = load_state()
        state[side][key] = argv[3] == "on"
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-flash-color":
        if len(argv) != 4 or argv[2] not in FLASH_BUTTONS or not re.fullmatch(r"[0-9A-Fa-f]{6}", argv[3]):
            print(f"usage: stick-led-color set-flash-color <{'|'.join(FLASH_BUTTONS)}> <RRGGBB hex>", file=sys.stderr)
            return 2
        state = load_state()
        state["flash_colors"][argv[2]] = argv[3].upper()
        save_state(state)
        return 0
    if command == "set-duotone-color":
        if len(argv) != 5 or argv[2] not in SIDES or argv[3] not in ("a", "b") or not re.fullmatch(r"[0-9A-Fa-f]{6}", argv[4]):
            print("usage: stick-led-color set-duotone-color <l|r> <a|b> <RRGGBB hex>", file=sys.stderr)
            return 2
        side, slot, value = argv[2], argv[3], argv[4].upper()
        state = load_state()
        state[side]["duotone_color_a" if slot == "a" else "duotone_color_b"] = value
        save_state(state)
        return 0 if apply_current() else 1
    if command == "set-duotone-orientation":
        if len(argv) != 4 or argv[2] not in SIDES or argv[3] not in DUOTONE_ORIENTATIONS:
            print(f"usage: stick-led-color set-duotone-orientation <l|r> <{'|'.join(DUOTONE_ORIENTATIONS)}>", file=sys.stderr)
            return 2
        side, orientation = argv[2], argv[3]
        state = load_state()
        state[side]["duotone_orientation"] = orientation
        save_state(state)
        return 0 if apply_current() else 1
    if command == "apply":
        return 0 if apply_current() else 1
    if command == "daemon":
        run_daemon()
        return 0
    if command == "test-zones":
        return cmd_test_zones()
    if command == "test-ambilight":
        if len(argv) > 2 and not argv[2].isdigit():
            print("usage: stick-led-color test-ambilight [seconds]", file=sys.stderr)
            return 2
        return cmd_test_ambilight(int(argv[2]) if len(argv) > 2 else 20)
    print(
        "usage: stick-led-color get|set <l|r> <RRGGBB>|set-mode <l|r> <mode>|set-enabled <on|off>|set-screen-link <on|off>"
        "|set-param <l|r> <param> <mode> <value>|set-color-source <l|r> <static|battery|random|shimmer>"
        "|set-charging-indicator <l|r> <on|off>|set-flash-color <button> <RRGGBB>"
        "|set-duotone-color <l|r> <a|b> <RRGGBB>|set-duotone-orientation <l|r> <horizontal|vertical|diagonal>"
        "|set-chase <l|r> <on|off>|set-compass <l|r> <on|off>|set-seesaw <l|r> <on|off>"
        "|apply|daemon|test-zones|test-ambilight [seconds]",
        file=sys.stderr,
    )
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
