# just converting a live push angle into the same continuous 0..4 "pos" unit
# chase/multidot already animate with a clock instead.
ZONE_BASE_ANGLE = 5 * math.pi / 4
ZONE_ANGLE_STEP = -math.pi / 2


def angle_to_chase_pos(theta):
    return ((ZONE_BASE_ANGLE - theta) / (-ZONE_ANGLE_STEP)) % len(ZONES)
BREATH_INTERVAL = 0.05
