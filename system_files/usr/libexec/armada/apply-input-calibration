#!/usr/bin/python3
import json
from pathlib import Path


CONFIG = Path("/etc/armada/input-calibration.json")
# Each supported gamepad driver exposes the same calibration parameter ABI
# (axis_*/trigger_* module params) under its own /sys/module/<name>/parameters -
# rsinput on AYN devices, retroid (drivers/input/joystick/retroid.c) on
# Retroid Pocket. Only one of these will exist on any given device.
CALIBRATION_DRIVER_MODULES = ("rsinput", "retroid")
PARAM_NAMES = (
    "axis_leftx_min",
    "axis_leftx_center",
    "axis_leftx_max",
    "axis_leftx_deadzone",
    "axis_leftx_antideadzone",
    "axis_lefty_min",
    "axis_lefty_center",
    "axis_lefty_max",
    "axis_lefty_deadzone",
    "axis_lefty_antideadzone",
    "axis_rightx_min",
    "axis_rightx_center",
    "axis_rightx_max",
    "axis_rightx_deadzone",
    "axis_rightx_antideadzone",
    "axis_righty_min",
    "axis_righty_center",
    "axis_righty_max",
    "axis_righty_deadzone",
    "axis_righty_antideadzone",
    "trigger_left_max",
    "trigger_left_deadzone",
    "trigger_left_antideadzone",
    "trigger_right_max",
    "trigger_right_deadzone",
    "trigger_right_antideadzone",
)


def main():
    if not CONFIG.exists():
        return
    parameters = next(
        (Path(f"/sys/module/{name}/parameters") for name in CALIBRATION_DRIVER_MODULES
         if Path(f"/sys/module/{name}/parameters").exists()),
        None,
    )
    if parameters is None:
        return
    with CONFIG.open(encoding="utf-8") as f:
        params = json.load(f)
    if not isinstance(params, dict):
        raise SystemExit("input calibration config must be a JSON object")
    for name in PARAM_NAMES:
        if name in params:
            (parameters / name).write_text(str(int(params[name])), encoding="utf-8")
    (parameters / "update_params").write_text("1", encoding="utf-8")


if __name__ == "__main__":
    main()
