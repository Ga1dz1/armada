#!/bin/sh
# Launches Eden (git.eden-emu.dev - a maintained post-DMCA Switch emulator
# fork; github.com/eden-emulator was taken down Feb 2026), vendored as a
# prebuilt aarch64 clang-PGO AppImage (see armada-packages/eden/build.sh).
#
# Pinned to the top half of available CPUs (the big/prime cluster on every
# SM8xxx SoC we support - confirmed for SM8250 via cpuinfo_max_freq
# elsewhere in this codebase, cpu4-7 at 2.4-2.84GHz vs cpu0-3's 1.8GHz).
# Ported from pocknix-os's es-eden wrapper: unpinned, Eden's emulated-core
# thread can land on a little core and pace badly - they verified this live
# on both RP6 (2026-07-07) and RP5 (2026-07-22).
N=$(nproc)
HALF=$((N / 2))
exec taskset -c "${HALF}-$((N - 1))" /usr/share/eden/Eden.AppImage "$@"
